#!/usr/bin/env bash
set -euo pipefail

library_root() {
  local path="$0"
  local dir
  local target

  while [ -L "$path" ]; do
    dir="$(cd -P "$(dirname "$path")" && pwd)"
    target="$(readlink "$path")"
    case "$target" in
      /*) path="$target" ;;
      *) path="${dir}/${target}" ;;
    esac
  done

  cd -P "$(dirname "$path")/.." && pwd
}

LIBRARY_ROOT="$(library_root)"
TEMPLATES_DIR="${LIBRARY_ROOT}/templates"
PINNED=".piqule/templates.md5"

if [ ! -f "$PINNED" ]; then
  exit 0
fi

if command -v md5sum >/dev/null 2>&1; then
  MD5_CMD=(md5sum)
elif command -v md5 >/dev/null 2>&1; then
  MD5_CMD=(md5 -r)
else
  echo "Error: neither md5sum nor md5 is available" >&2
  exit 1
fi

CURRENT="$(find "$TEMPLATES_DIR/always" "$TEMPLATES_DIR/git" -type f \
  | sort \
  | xargs "${MD5_CMD[@]}" \
  | "${MD5_CMD[@]}" \
  | awk '{print $1}')"

if [ "$CURRENT" != "$(cat "$PINNED")" ]; then
  printf "\033[31mTemplates have changed. Run: sheriff sync\033[0m\n\n"
else
  printf "\033[90mTemplates are up to date\033[0m\n\n"
fi
