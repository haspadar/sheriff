#!/usr/bin/env bash
set -euo pipefail

# ------------------------------------------------------------
# Ensure we are in project root
# ------------------------------------------------------------
ensure_project_root() {
  if [ ! -d ".piqule" ]; then
    echo "Error: run ${PROGRAM} from project root ('.piqule' directory not found)"
    exit 1
  fi
}

PROGRAM="${PIQULE_COMMAND_NAME:-$(basename "$0")}"
COMMAND="${1:-}"
shift || true

case "$COMMAND" in
  sync)
    "$(dirname "$0")/sheriff-sync" "$@"
    "$(dirname "$0")/sheriff-pin"
    "$(dirname "$0")/sheriff-tokens-check"
    "$(dirname "$0")/sheriff-agent-rules-check"
    ;;
  check|fix)
    ensure_project_root
    "$(dirname "$0")/sheriff-verify"
    "$(dirname "$0")/sheriff-${COMMAND}" "$@"
    "$(dirname "$0")/sheriff-tokens-check"
    "$(dirname "$0")/sheriff-agent-rules-check"
    ;;
  agent-rules-install)
    "$(dirname "$0")/sheriff-agent-rules-install" "$@"
    ;;
  *)
    echo "Usage: ${PROGRAM} [sync|check|fix|agent-rules-install]"
    exit 1
    ;;
esac
