{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": ["config:recommended"],

  "schedule": ["* 1-4 * * *"],
  "timezone": "UTC",

  "labels": ["dependencies"],
  "prConcurrentLimit": 3,
  "prHourlyLimit": 0,

  "enabledManagers": [
    "composer",
    "github-actions",
    "dockerfile",
    "custom.regex"
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },

  "packageRules": [
    {
      "description": "Update pinned GitHub Actions SHAs",
      "matchManagers": ["github-actions"],
      "updatePinnedDependencies": true
    },
    {
      "description": "Automerge infra linters (patch/minor)",
      "matchDatasources": ["github-releases", "npm"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Do not automerge docker images",
      "matchDatasources": ["docker"],
      "automerge": false
    },
    {
      "description": "Mark major updates as breaking",
      "matchUpdateTypes": ["major"],
      "labels": ["breaking"]
    },
    {
      "description": "No major updates for composer packages",
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ],

  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "ARG DEBIAN_IMAGE=(?<depName>[^:]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "ARG NODE_MAJOR=(?<currentValue>\\d+)"
      ],
      "depNameTemplate": "node",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "ARG ACTIONLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "rhysd/actionlint",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "ARG HADOLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "hadolint/hadolint",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "ARG TYPOS_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "crate-ci/typos",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "ARG SHELLCHECK_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "koalaman/shellcheck",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "ARG MARKDOWNLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "markdownlint-cli2",
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "ARG JSONLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "@prantlf/jsonlint",
      "datasourceTemplate": "npm"
    }
  ]
}